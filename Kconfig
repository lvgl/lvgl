# Kconfig file for LVGL v9.5.0

menu "LVGL"

	config LVGL_VERSION_MAJOR
		int
		default 9
	config LVGL_VERSION_MINOR
		int
		default 6
	config LVGL_VERSION_PATCH
		int
		default 0

	config LVGL_DIR
		string
		option env="LVGL_DIR"

	menu "Memory and Standard Library"
		source "$LVGL_DIR/src/stdlib/Kconfig"
	endmenu 

	menu "Operating System (OS)"
		source "$LVGL_DIR/src/osal/Kconfig"
	endmenu

	menu "Rendering Configuration"
		source "$LVGL_DIR/src/draw/Kconfig"
	endmenu

	menu "Input Devices"
		source "$LVGL_DIR/src/indev/Kconfig"
	endmenu

	menu "Core"
		source "$LVGL_DIR/src/core/Kconfig"
	endmenu

	menu "Logging"
		source "$LVGL_DIR/src/logging/Kconfig"
	endmenu

	menu "Themes"
		source "$LVGL_DIR/src/themes/Kconfig"
	endmenu

	menu "Layouts"
		source "$LVGL_DIR/src/layouts/Kconfig"
	endmenu
	
	menu "Image Settings"
		source "$LVGL_DIR/src/image/Kconfig"
	endmenu

	menu "Text & Font Settings"
		source "$LVGL_DIR/src/font/Kconfig"
	endmenu

	menu "Widgets"
		source "$LVGL_DIR/src/widgets/Kconfig"
	endmenu

	menu "Drivers"
		source "$LVGL_DIR/src/drivers/Kconfig"
	endmenu

	menu "File System"
		source "$LVGL_DIR/src/fs/Kconfig"
	endmenu

	menu "Debugging"
		source "$LVGL_DIR/src/debugging/Kconfig"
	endmenu

	menu "Others"
		source "$LVGL_DIR/src/others/Kconfig"
	endmenu

	menu "Build"
		source "$LVGL_DIR/env_support/kconfig/Kconfig.build"
	endmenu 

	menu "Compiler Settings"
		source "$LVGL_DIR/env_support/kconfig/Kconfig.compiler"
	endmenu

	menu "Examples"
		source "$LVGL_DIR/examples/Kconfig"
	endmenu

	menu "Demos"
		source "$LVGL_DIR/demos/Kconfig"
	endmenu
endmenu
