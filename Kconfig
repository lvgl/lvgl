# Kconfig file for LVGL v9.5.0
#
menu "LVGL"

	config LVGL_VERSION_MAJOR
		int
		default 9
	config LVGL_VERSION_MINOR
		int
		default 6
	config LVGL_VERSION_PATCH
		int
		default 0

	menu "Build"
		rsource "env_support/kconfig/Kconfig.build"
	endmenu 

	menu "Memory and Standard Library"
