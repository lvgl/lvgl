@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_lvgl_public_deps "@LVGL_CMAKE_PUBLIC_DEPS@")
foreach(_dep IN LISTS _lvgl_public_deps)
  find_dependency(${_dep})
endforeach()

set(_lvgl_private_deps "@LVGL_CMAKE_PRIVATE_DEPS@")
foreach(_dep IN LISTS _lvgl_private_deps)
  find_dependency(${_dep})
endforeach()

unset(_lvgl_public_deps)
unset(_lvgl_private_deps)

include("${CMAKE_CURRENT_LIST_DIR}/lvglTargets.cmake")

check_required_components(lvgl)
