    <subjects>
        <!-- Generic subjects used by the data-binding examples. Each binding
             example reuses these so users don't have to invent new subject
             names per example. -->
        <int    name="subject_value"  value="50"  min_value="0" max_value="100"/>
        <int    name="subject_value2" value="20"  min_value="0" max_value="100"/>
        <int    name="subject_opa"    value="128" min_value="0" max_value="255"/>
        <int    name="subject_index"  value="0"/>
        <int    name="subject_flag"   value="0"/>
        <string name="subject_text"   value="Hello"/>
    </subjects>

    <images>
        <!-- The name matches the pre-built `img_lvgl_logo` descriptor in
             `demos/widgets/assets/img_lvgl_logo.c`, so the generated C links
             against that symbol and the example doesn't depend on the
             editor's image-conversion pipeline. `src_path` is only the
             editor's preview/source. -->
        <file name="img_lvgl_logo" src_path="images/img_lvgl_logo.png" />
    </images>

    <fonts>
        <!-- Add <bin> , <tiny_ttf>, <freetype> tags here -->
    </fonts>
