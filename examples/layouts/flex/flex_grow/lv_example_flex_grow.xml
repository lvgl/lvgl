<screen>
	<view flex_flow="column">
		<!-- 💡 Adjust the flex_grow values (e.g. 1, 3, 5) to see how free space is distributed. -->
		<lv_label width="100%" style_text_align="center" text="Flex grow: distribute remaining space proportionally" />

		<!-- A row with 3 items. The first have fixed widths.
		     The middle and the right items grow to fill the remaining space.
		     "A" gets 1 portion, "B" gets 2 portions of the free space.
		     Try changing the style_flex_grow values to see the effect. -->
		<!-- Demo row for grow behavior -->
		<lv_obj flex_flow="row" width="100%" height="content">
			<!-- Fixed-width item on the left -->
			<lv_button width="50" height="content">
				<lv_label text="Fix" align="center" />
			</lv_button>

			<!-- Grows with weight 1 -->
			<lv_button height="content" flex_grow="1">
				<lv_label text="Grow x1" align="center" />
			</lv_button>

			<!-- Grows with weight 2 — receives twice as much free space -->
			<lv_button height="content" flex_grow="2">
				<lv_label text="Grow x2" align="center" />
			</lv_button>
		</lv_obj>
	</view>
</screen>
