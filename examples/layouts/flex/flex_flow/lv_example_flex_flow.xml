<!--
 @title Flex flow
 @brief Arrange children with a flex flow direction.

 A single row_wrap container holds enough buttons to overflow one line, so wrapping kicks
 in. Try other flex_flow values (row, column, row_reverse, column_wrap_reverse) to see
 how item order and wrap direction change with the same set of children.
-->
<screen>
	<view flex_flow="column">
		<!-- 💡 Adjust flex_flow (row, column, row_wrap, row_reverse) to see how item order and wrapping change. -->
		<lv_label width="100%" style_text_align="center" text="Buttons Arranged in a row with automatic wrapping" />

		<!-- Try other values for flex_flow, such as "row", "column", "column_wrap_reverse" -->
		<!-- Demo container with row wrapping -->
		<lv_obj flex_flow="row_wrap" width="100%" height="50%" name="example_flex_flow">
			<!-- Item sequence to visualize wrapping -->
			<lv_button>
				<lv_label text="First" />
			</lv_button>

			<lv_button>
				<lv_label text="Second" />
			</lv_button>

			<lv_button>
				<lv_label text="Third" />
			</lv_button>

			<lv_button>
				<lv_label text="Forth" />
			</lv_button>

			<lv_button>
				<lv_label text="Fifth" />
			</lv_button>

			<lv_button>
				<lv_label text="Sixth" />
			</lv_button>

			<lv_button>
				<lv_label text="Seventh" />
			</lv_button>

			<lv_button>
				<lv_label text="Eighth" />
			</lv_button>

			<lv_button>
				<lv_label text="Ninth" />
			</lv_button>

			<lv_button>
				<lv_label text="Tenth" />
			</lv_button>
		</lv_obj>
	</view>
</screen>
