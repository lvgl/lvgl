<!--
 @title Bar orientation and size
 @brief Compare horizontal and explicit vertical bars.

 The horizontal bar uses the default orientation derived from a wide-and-short size. The
 vertical one sets orientation="vertical" explicitly and uses a tall, narrow size so the
 indicator grows upward instead of left-to-right.
-->
<screen>
	<consts>
		<color name="text_color" value="0x013992" />
	</consts>
	<view flex_flow="column" style_flex_cross_place="center" style_pad_row="16">
		<!-- 💡 Swap width/height or set orientation explicitly to flip the indicator's travel direction. -->
		<lv_label width="100%" style_text_align="center" text="Bar: orientation and size" />

		<!-- Horizontal bar (auto orientation from width &gt; height) -->
		<lv_bar width="90%" height="16" min_value="0" max_value="100" value="60">
			<lv_label align="center" text="horizontal" style_text_color="#text_color" />
		</lv_bar>

		<!-- Explicit vertical orientation -->
		<lv_bar width="18" height="130" orientation="vertical" min_value="0" max_value="100" value="60">
			<lv_label align="center" text="V&#10;e&#10;r" style_text_align="center" style_text_color="#text_color" />
		</lv_bar>
	</view>
</screen>
