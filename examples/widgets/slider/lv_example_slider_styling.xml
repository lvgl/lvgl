<!--
 @title Slider styling
 @brief Style MAIN, INDICATOR, and KNOB — including a pressed-state knob highlight.

 Slider has three parts: MAIN (track), INDICATOR (filled portion), and KNOB. The
 example targets each with a named style. The knob also gets a second style with
 `selector="pressed|knob"` so it picks up an outline halo and a brighter fill only
 while being dragged, demonstrating combined part+state selectors.
-->
<screen>
	<consts>
		<color name="text_color" value="0x013992" />
	</consts>
	<styles>
		<!-- Track: rounded, inset, dark fill -->
		<style
			name="style_slider_track"
			bg_opa="100%"
			bg_color="0x1f2937"
			radius="12"
			border_color="0x0f172a"
			border_width="1"
		/>
		<!-- Indicator: vibrant gradient with soft glow -->
		<style
			name="style_slider_indicator"
			bg_opa="100%"
			bg_color="0x8b5cf6"
			bg_grad_color="0xec4899"
			bg_grad_dir="hor"
			radius="12"
			shadow_color="0x6d28d9"
			shadow_width="12"
			shadow_spread="-1"
			shadow_opa="150"
		/>
		<!-- Knob: pill shape, light fill, ring outline -->
		<style
			name="style_slider_knob"
			bg_opa="100%"
			bg_color="0xffffff"
			radius="100"
			border_color="0x8b5cf6"
			border_width="3"
			pad_all="6"
			shadow_color="0x000000"
			shadow_width="8"
			shadow_offset_y="2"
			shadow_opa="80"
		/>
		<!-- Knob, pressed: brighter fill + outline halo -->
		<style
			name="style_slider_knob_pressed"
			bg_color="0xfff7ed"
			outline_color="0xec4899"
			outline_width="6"
			outline_pad="4"
			outline_opa="120"
		/>
	</styles>

	<view flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center" style_flex_track_place="center" style_pad_row="20">
		<!-- 💡 Drag the knob slowly to see the knob-pressed style kick in. -->
		<lv_slider name="slider" width="90%" height="22" min_value="0" max_value="100" value="55">
			<style name="style_slider_track" selector="main" />
			<style name="style_slider_indicator" selector="indicator" />
			<style name="style_slider_knob" selector="knob" />
			<style name="style_slider_knob_pressed" selector="pressed|knob" />
		</lv_slider>
	</view>
</screen>
