<screen>
	<view>
		<!-- 💡 Edit start_angle/end_angle directly to draw any indicator span independent of value and mode. -->
		<lv_label width="100%" style_text_align="center" text="Arc: set indicator angles" />

		<!-- Value-driven indicator arc -->
		<lv_arc
			x="14"
			y="34"
			width="96"
			height="96"
			bg_start_angle="135"
			bg_end_angle="45"
			min_value="100"
			max_value="200"
			value="145"
		>
			<lv_label align="center" text="value" />
		</lv_arc>

		<!-- Indicator angle set explicitly; value/mode are ignored for indicator drawing -->
		<lv_arc
			x="130"
			y="34"
			width="96"
			height="96"
			bg_start_angle="135"
			bg_end_angle="45"
			start_angle="210"
			end_angle="330"
		>
			<lv_label align="center" text="angles" />
		</lv_arc>
	</view>
</screen>
