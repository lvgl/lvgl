<!--
 @title Background gradient
 @brief Blend two colors vertically and shift where the blend happens.

 `bg_color` and `bg_grad_color` are the two stops; `bg_grad_dir="ver"`
 blends top-to-bottom. `bg_main_stop="80"` keeps the indigo solid only
 briefly and `bg_grad_stop="220"` stretches the blend almost to the
 bottom, so most of the card is transition rather than flat color.
-->
<screen>
	<styles>
		<!-- Indigo→pink vertical blend with a matching glow -->
		<style name="style_grad"
			radius="20"
			bg_opa="100%"
			bg_color="0x6366f1"
			bg_grad_color="0xec4899"
			bg_grad_dir="ver"
			bg_main_stop="80"
			bg_grad_stop="220"
			shadow_color="0x6366f1"
			shadow_width="26"
			shadow_offset_y="10"
			shadow_opa="70"
			text_color="0xffffff" />
	</styles>

	<view flex_flow="column" style_flex_cross_place="center" style_pad_row="16">
		<!-- 💡 Slide `bg_main_stop`/`bg_grad_stop` (0..255) to move where the indigo→pink blend starts and ends. -->
		<lv_label width="100%" style_text_align="center" text="Style: background gradient" />

		<lv_obj width="210" height="150">
			<style name="style_grad" />
			<lv_label align="center" text="Gradient" />
		</lv_obj>
	</view>
</screen>
