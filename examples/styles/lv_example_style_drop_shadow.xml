<!--
 @title Drop shadow
 @brief Blur the indicator's actual shape into a colored, offset shadow.

 Unlike `shadow_*`, which is always a rectangle, `drop_shadow_*` blurs the
 real shape of the part. On `selector="indicator"` the arc's active band
 gets a red shadow: `drop_shadow_radius="16"` softens it and
 `drop_shadow_offset_x`/`drop_shadow_offset_y` push it off the curve it traces.
-->
<screen>
	<styles>
		<!-- Red shadow that follows the arc band, not a bounding box -->
		<style name="style_drop"
			drop_shadow_color="0xf44336"
			drop_shadow_radius="16"
			drop_shadow_opa="100%"
			drop_shadow_offset_x="5"
			drop_shadow_offset_y="10" />
	</styles>

	<view flex_flow="column" style_flex_main_place="center" style_flex_cross_place="center" style_flex_track_place="center" style_pad_row="16">
		<!-- 💡 The shadow follows the arc's curve, not a box; change `drop_shadow_offset_x`/`drop_shadow_offset_y` to slide it. -->
		<lv_arc name="arc" width="150" height="150" min_value="0" max_value="100" value="60">
			<style name="style_drop" selector="indicator" />
		</lv_arc>
	</view>
</screen>
